<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Home"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/oswald"
                android:text="Selamat datang,"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/oswald"
                android:text="Nabil Apps"
                android:textColor="@android:color/black"
                android:textSize="28sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:columnOrderPreserved="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSecond"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 2"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToThird"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 3"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFourth"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 4"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToFifth"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 5"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToSeventh"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 7"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToNinth"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 9"
                    android:textAllCaps="false"
                    android:textColor="#3F51B5"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0" />

            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#FF5252"
                android:padding="12dp"
                android:text="Keluar Aplikasi"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>